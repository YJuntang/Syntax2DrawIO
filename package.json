{
  "name": "syntax2drawio",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syntax2drawio/syntax2drawio.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "deploy": "npm run build && wrangler pages deploy dist",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:mac-universal": "tauri build --target universal-apple-darwin --bundles dmg",
    "desktop:build:win-x64": "tauri build --target x86_64-pc-windows-msvc --bundles msi",
    "desktop:info": "tauri info"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@xmldom/xmldom": "^0.8.13",
    "clsx": "^2.0.0",
    "dompurify": "^3.4.10",
    "immer": "^10.0.3",
    "lucide-react": "^0.294.0",
    "mermaid": "^10.6.1",
    "monaco-editor": "^0.45.0",
    "pako": "^2.1.0",
    "plantuml-encoder": "^1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.1.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231101.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/dompurify": "^3.0.5",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^1.0.4",
    "workbox-precaching": "^7.4.1",
    "workbox-window": "^7.4.1",
    "wrangler": "^3.20.0"
  }
}
